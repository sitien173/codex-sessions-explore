{
  "name": "codex-session-explorer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "concurrently --names \"index,vite\" --prefix-colors \"cyan,magenta\" \"npm:build-index:watch\" \"npm:dev\"",
    "build-index": "npx tsx scripts/build-index.ts --sessions-dir /data/share/.codex/sessions",
    "build-index:custom": "npx tsx scripts/build-index.ts",
    "build-index:watch": "npx tsx scripts/build-index.ts --sessions-dir /data/share/.codex/sessions --watch",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "minisearch": "^7.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}